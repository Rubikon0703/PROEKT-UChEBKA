#include "mqtt_manager.h"
#include "esp_log.h"
#include "esp_mqtt_client.h"
#include "cJSON.h"
#include <stdio.h>
#include <string.h>

static const char *TAG = "mqtt";
static esp_mqtt_client_handle_t client = NULL;
static bool connected = false;

extern const uint8_t mosquitto_org_crt_start[] asm("_binary_mosquitto_org_crt_start");
extern const uint8_t mosquitto_org_crt_end[] asm("_binary_mosquitto_org_crt_end");

static void mqtt_handler(void *args, esp_event_base_t base, int32_t id, void *data) {
    esp_mqtt_event_handle_t ev = data;
    switch (id) {
        case MQTT_EVENT_CONNECTED: connected = true; ESP_LOGI(TAG, "Connected"); break;
        case MQTT_EVENT_DISCONNECTED: connected = false; ESP_LOGW(TAG, "Disconnected"); break;
        case MQTT_EVENT_PUBLISHED: ESP_LOGI(TAG, "Published msg_id=%d", ev->msg_id); break;
        case MQTT_EVENT_ERROR: ESP_LOGE(TAG, "Error"); connected = false; break;
        default: break;
    }
}

esp_err_t mqtt_init(const char *uri, const char *client_id) {
    if (client) return ESP_OK;
    esp_mqtt_client_config_t cfg = {
        .broker.address.uri = uri,
        .credentials.client_id = client_id,
        .broker.verification.certificate = (const char *)mosquitto_org_crt_start,
        .session.last_will.topic = "sensors/status",
        .session.last_will.msg = "offline",
        .session.last_will.qos = 1,
        .session.last_will.retain = true,
    };
    client = esp_mqtt_client_init(&cfg);
    if (!client) return ESP_FAIL;
    esp_mqtt_client_register_event(client, ESP_EVENT_ANY_ID, mqtt_handler, NULL);
    return ESP_OK;
}

esp_err_t mqtt_connect(void) {
    if (!client) return ESP_ERR_INVALID_STATE;
    esp_err_t r = esp_mqtt_client_start(client);
    if (r != ESP_OK) return r;
    int to = 50;
    while (!connected && to--) vTaskDelay(pdMS_TO_TICKS(100));
    return connected ? ESP_OK : ESP_ERR_TIMEOUT;
}

esp_err_t mqtt_publish_sensor_data(const sensor_data_t *d, const char *topic) {
    if (!client || !connected || !d || !topic) return ESP_ERR_INVALID_STATE;
    cJSON *root = cJSON_CreateObject();
    cJSON_AddNumberToObject(root, "ts", d->timestamp_ms);
    cJSON_AddNumberToObject(root, "temperature", d->temperature);
    cJSON_AddNumberToObject(root, "light", d->light);
    cJSON_AddNumberToObject(root, "distance", d->distance);
    cJSON_AddBoolToObject(root, "rfid", d->rfid_detected);
    if (d->rfid_detected) cJSON_AddNumberToObject(root, "uid", d->rfid_uid);
    char *json = cJSON_PrintUnformatted(root);
    int mid = esp_mqtt_client_publish(client, topic, json, 0, 1, false);
    cJSON_free(json); cJSON_Delete(root);
    return (mid >= 0) ? ESP_OK : ESP_FAIL;
}

void mqtt_disconnect(void) {
    if (client && connected) {
        esp_mqtt_client_publish(client, "sensors/status", "offline", 0, 1, true);
        esp_mqtt_client_stop(client);
        connected = false;
    }
}
